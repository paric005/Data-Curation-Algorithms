    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# Load dataset\n",
    "covid = pd.read_csv(\"covid_19_clean_complete.csv\")\n",
    "\n",
    "# 1. Clean the dataset\n",
    "covid = covid[['Date', 'Country/Region', 'Confirmed', 'Deaths']]   # select relevant cols\n",
    "covid = covid.dropna()                                            # remove nulls\n",
    "covid['Date'] = pd.to_datetime(covid['Date'])                     # ensure datetime\n",
    "\n",
    "# 2. Select two countries (India & USA as example)\n",
    "countries = [\"India\", \"US\"]\n",
    "\n",
    "plt.figure(figsize=(12,6))\n",
    "\n",
    "for country in countries:\n",
    "    country_data = covid[covid['Country/Region'] == country]\n",
    "    plt.plot(country_data['Date'], country_data['Confirmed'], label=country)\n",
    "\n",
    "# Chart formatting\n",
    "plt.title(\"COVID-19 Cases Over Time\")\n",
    "plt.xlabel(\"Date\")\n",
    "plt.ylabel(\"Confirmed Cases\")\n",
    "plt.legend()\n",
    "plt.grid(True)\n",
    "plt.show()"
   ]
