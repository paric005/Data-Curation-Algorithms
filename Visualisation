    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "# Step 1: Create DataFrame\n",
    "data = pd.DataFrame({\n",
    "    'ID': [1, 2, 3, 4, 5],\n",
    "    'Name': ['Amit', 'Neha', 'Rahul', 'Priya', 'Sandeep'],\n",
    "    'Age': [20, np.nan, 21, np.nan, 22],\n",
    "    'Marks': [85, 90, np.nan, 78, 88],\n",
    "    'Gender': ['M', 'F', 'M', 'F', 'M']\n",
    "})\n",
    "\n",
    "print(\"📘 Original Data:\")\n",
    "print(data)\n",
    "\n",
    "# Step 2: Detect missing values\n",
    "print(\"\\n🔍 Missing Values Count:\")\n",
    "print(data.isnull().sum())\n",
    "\n",
    "# Step 3: Replace missing 'Age' with mean age\n",
    "mean_age = data['Age'].mean()\n",
    "data['Age'].fillna(mean_age, inplace=True)\n",
    "\n",
    "# Step 4: Replace missing 'Marks' with median marks\n",
    "median_marks = data['Marks'].median()\n",
    "data['Marks'].fillna(median_marks, inplace=True)\n",
    "\n",
    "# Step 5: Show cleaned data\n",
    "print(\"\\n✅ After Handling Missing Values:\")\n",
    "print(data)\n",
    "\n",
    "# (Optional) Check again for missing values\n",
    "print(\"\\n🔁 Remaining Missing Values:\")\n",
    "print(data.isnull().sum())\n"
   ]
